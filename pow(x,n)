class Solution {
public:
    double myPow(double x, int n) {
        long m=n;
        if(x==1.0) return x;
        int orig=n;
        double ans=1;
        if(m<0) m=-m;
        while(m>0){
            if(m%2==1){
                ans=ans*x;
                m=m-1;
            }
            else{
                m=m/2;
                x=x*x;
            }
        }
        if (orig<0) ans=1.0/ans;
        return ans;
        
    }
};
